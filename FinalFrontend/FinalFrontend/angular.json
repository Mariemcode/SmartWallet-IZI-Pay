{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "projects": {
    "smartwallet-admin-final": {
      "projectType": "application",
      "root": "",
      "sourceRoot": ".",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/smartwallet-admin-final",
            "index": "index.html",
            "main": "main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "styles": ["styles.css"],
            "scripts": [],
            "assets": [
              {
                "glob": "**/*",
                "input": "assets",
                "output": "assets"
              }
            ]
          },
          "configurations": {
            "production": {
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "aot": true,
              "buildOptimizer": true,
              "fileReplacements": [
                {
                  "replace": "environments/environment.ts",
                  "with": "environments/environment.prod.ts"
                }
              ]
            },
            "development": {
              "optimization": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "development"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "buildTarget": "smartwallet-admin-final:build",
            "proxyConfig": "proxy.conf.json"
          },
          "configurations": {
            "production": {
              "buildTarget": "smartwallet-admin-final:build:production"
            },
            "development": {
              "buildTarget": "smartwallet-admin-final:build:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
